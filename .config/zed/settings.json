{
  // ═══════════════════════════════════════════════════════════
  // 🎨 THEME & UI
  // ═══════════════════════════════════════════════════════════
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "ui_font_family": ".ZedSans",
  "ui_font_size": 15,
  "ui_font_weight": 400,
    "outline_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },

  // ═══════════════════════════════════════════════════════════
  // ✍️ EDITOR — FONTS, CURSOR, VISUALS
  // ═══════════════════════════════════════════════════════════
  "buffer_font_family": "JetBrains Mono Nerd Font",
  "buffer_font_size": 16,
  "buffer_font_fallbacks": ["Noto Color Emoji"],
  "buffer_font_features": {
    "calt": true,
    "liga": true,
  },
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 400,
  "cursor_shape": "bar",
  "cursor_blink": true,
  "current_line_highlight": "line",
  "selection_highlight": true,
  "unnecessary_code_fade": 0.2,
  "rounded_selection": true,

  // ═══════════════════════════════════════════════════════════
  // 📏 WRAPPING, GUIDES, WHITESPACE
  // ═══════════════════════════════════════════════════════════
  "preferred_line_length": 100,
  "show_wrap_guides": true,
  "wrap_guides": [80, 120],
  "soft_wrap": "editor_width",
  "show_whitespaces": "selection",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "active_line_width": 2,
  },

  // ═══════════════════════════════════════════════════════════
  // 🧭 GUTTER, SCROLL, NAVIGATION
  // ═══════════════════════════════════════════════════════════
  "gutter": {
    "line_numbers": true,
    "folds": true,
    "breakpoints": true,
    "runnables": true,
    "min_line_number_digits": 2,
  },
  "relative_line_numbers": "disabled",
  "scroll_beyond_last_line": "off",
  "horizontal_scroll_margin": 5,
  "vertical_scroll_margin": 3,
  "hide_mouse": "on_typing_and_movement",
  "scroll_sensitivity": 1.2,
  "fast_scroll_sensitivity": 4.8,
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "diagnostics": "error",
    "selected_text": true,
    "cursors": true,
  },

  // ═══════════════════════════════════════════════════════════
  // 💾 SAVE, FORMAT, EDIT BEHAVIOR
  // ═══════════════════════════════════════════════════════════
  "autosave": "on_focus_change",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "use_autoclose": true,
  "use_auto_surround": true,
  "linked_edits": true,
  "extend_comment_on_newline": true,

  // ═══════════════════════════════════════════════════════════
  // 🗂️ TABS, PANELS, LAYOUT
  // ═══════════════════════════════════════════════════════════
  "max_tabs": 15,
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_close_button": "hover",
    "activate_on_close": "history",
    "show_diagnostics": "errors",
  },
  "title_bar": {
    "show_branch_icon": true,
    "show_branch_name": true,
    "show_project_items": true,
    "show_user_picture": false,
    "show_menus": false,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "code_actions": false,
    "agent_review": true,
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": false,
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "default_width": 260,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
    "hide_root": false,
    "hide_hidden": false,
    "scrollbar": {
      "show": "auto",
    },
    "indent_guides": {
      "show": "always",
    },
    "show_diagnostics": "all",
    "sort_mode": "directories_first",
  },
  "git_panel": {
    "button": true,
    "dock": "right",
    "default_width": 320,
    "status_style": "icon",
    "sort_by_path": false,
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left",
  },

  // ═══════════════════════════════════════════════════════════
  // 🔀 GIT
  // ═══════════════════════════════════════════════════════════
  "git": {
    "git_gutter": "tracked_files",
    "hunk_style": "staged_hollow",
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "delay_ms": 300,
    },
  },

  // ═══════════════════════════════════════════════════════════
  // 💻 TERMINAL
  // ═══════════════════════════════════════════════════════════
  "terminal": {
    "button": true,
    "dock": "bottom",
    "font_family": "JetBrains Mono Nerd Font",
    "font_size": 14,
    "line_height": "comfortable",
    "cursor_shape": "block",
    "blinking": "terminal_controlled",
    "copy_on_select": true,
    "keep_selection_on_copy": true,
    "working_directory": "current_project_directory",
    "detect_venv": {
      "on": {
        "directories": [".env", "env", ".venv", "venv", ".expo"],
      },
    },
    "scrollbar": {
      "show": "auto",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
    "minimum_contrast": 45,
  },
  "load_direnv": "shell_hook",
  "middle_click_paste": true,

  // ═══════════════════════════════════════════════════════════
  // 🔍 SEARCH, FIND, PREVIEW
  // ═══════════════════════════════════════════════════════════
  "use_system_path_prompts": false,
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_project_panel": true,
    "enable_preview_from_file_finder": false,
    "enable_preview_from_multibuffer": true,
  },
  "search": {
    "case_sensitive": false,
    "include_ignored": false,
    "regex": false,
    "whole_word": false,
  },
  "seed_search_query_from_cursor": "selection",

  // ═══════════════════════════════════════════════════════════
  // 🤖 AI, LSP, INTELLISENSE — DISABLED
  // ═══════════════════════════════════════════════════════════
  "edit_predictions": {
    "provider": "none",
  },
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "snippet_sort_order": "inline",
  "auto_signature_help": true,
  "hover_popover_enabled": false,
  "hover_popover_delay": 300,
  "inlay_hints": {
    "enabled": false,
    "edit_debounce_ms": 100,
    "scroll_debounce_ms": 50,
    "show_background": true,
    "show_parameter_hints": false,
    "show_type_hints": false,
    "show_other_hints": false,
  },
  "lsp_document_colors": "inlay",
  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "button": true,
    "request_timeout": 120,
    "notifications": {
      "dismiss_timeout_ms": 5000,
    },
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": false,
    },
  },
  "diagnostics_max_severity": "warning",

  // ═══════════════════════════════════════════════════════════
  // 🐍⚛️ LANGUAGE-SPECIFIC
  // ═══════════════════════════════════════════════════════════
  "languages": {
    "Python": {
      "tab_size": 4,
      "hard_tabs": false,
      "preferred_line_length": 88,
      "format_on_save": "on",
      "enable_language_server": true,
      "document_symbols": "on",
      "indent_guides": {
        "enabled": true,
        "coloring": "indent_aware",
      },
    },
    "TypeScript": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "enable_language_server": true,
      "document_symbols": "on",
      "semantic_tokens": "combined",
      "edit_predictions_disabled_in": ["comment"],
    },
    "JavaScript": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "enable_language_server": true,
      "document_symbols": "on",
    },
    "TSX": {
      "tab_size": 2,
      "hard_tabs": false,
      "format_on_save": "on",
      "enable_language_server": true,
      "document_symbols": "on",
      "edit_predictions_disabled_in": ["comment", "string"],
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on",
    },
    "JSONC": {
      "tab_size": 2,
    },
  },

  // ═══════════════════════════════════════════════════════════
  // 🗄️ FILE SCAN, EXCLUSIONS
  // ═══════════════════════════════════════════════════════════
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/.expo/**",
    "**/.expo-shared/**",
    "**/.venv/**",
    "**/__pycache__/**",
    "**/.mypy_cache/**",
    "**/.bun/**",
    "**/.npm/**",
    "**/.pnpm-store/**",
    "**/.yarn/**",
    "**/.yarn/cache/**",
    "**/.yarn/unplugged/**",
    "**/.cache/**",
    "**/.turbo/**",
  ],
  "file_types": {
    "Shell Script": [".env.*"],
    "JSONC": ["**/.vscode/**/*.json"],
  },

  // ═══════════════════════════════════════════════════════════
  // ⚙️ PERFORMANCE
  // ═══════════════════════════════════════════════════════════
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.85,
  },

  // ═══════════════════════════════════════════════════════════
  // 🔒 TELEMETRY / PRIVACY
  // ═══════════════════════════════════════════════════════════
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "auto_update": true,
  "confirm_quit": false,
  "restore_on_startup": "last_workspace",
  "session": {
    "restore_unsaved_buffers": true,
    "trust_all_worktrees": false,
  },
  "close_on_file_delete": false,
  "drag_and_drop_selection": {
    "enabled": true,
    "delay": 300,
  },
}
