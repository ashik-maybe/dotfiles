set recolor-darkcolor         "rgba(87,82,121,1)"     # text

set index-fg                  "rgba(87,82,121,1)"     # text
set index-bg                  "rgba(250,244,237,1)"   # base
set index-active-fg           "rgba(87,82,121,1)"     # text
set index-active-bg           "rgba(242,233,222,1)"   # surface

set render-loading-bg         "rgba(250,244,237,1)"   # base
set render-loading-fg         "rgba(87,82,121,1)"     # text

set highlight-color           "rgba(223,216,211,0.5)" # highlight low
set highlight-fg              "rgba(87,82,121,1)"     # text
set highlight-active-color    "rgba(144,122,169,0.4)" # iris (semi-transparent)
