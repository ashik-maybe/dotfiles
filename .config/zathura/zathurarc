# Theme
include catppuccin-mocha
# include catppuccin-latte

# Force document pages to render using the theme colors by default
set recolor                  "true"

# Interface UI
set show-scrollbars           "false"       # Strips out bulky visual scroll bars
set window-title-basename     "true"        # Window title shows file name only

# Mouse & Trackpad Handling
set scroll-step               40            # Tightens scrolling distance per wheel notch
set link-hadjust              "true"        # Aligns view with clicked internal links
set link-click-sets-history   "true"        # Trackpad clicks are saved to history back-stack

# Chrome Zoom Bindings (Keyboard + Mouse Wheel Combo)
map <C-=>                     zoom in
map <C-+>                     zoom in
map <C-->                     zoom out
map <C-0>                     adjust_window best-fit
map <C-9>                     adjust_window width      # Scale layout to perfectly fit panel width
map <C-ScrollUp>              zoom in       # Chrome-style: Ctrl + scroll up to zoom
map <C-ScrollDown>            zoom out      # Chrome-style: Ctrl + scroll down to zoom

# Chrome Navigation
map <Down>                    feedkeys "<C-Down>"
map <Up>                      feedkeys "<C-Up>"
map <Left>                    scroll left
map <Right>                   scroll right
map <Space>                   scroll full-down
map <S-Space>                 scroll full-up

# Chrome History Navigation (Back / Forward)
map <A-Left>                  navigate back     # Alt + Left to go back a clicked link
map <A-Right>                 navigate next     # Alt + Right to go forward

# Study Utilities
map i                         recolor             # Inverts document light/dark colors
set recolor-keep-hue          "true"              # Protects original hues of images/charts
map d                         toggle_page_mode    # Side-by-side presentation mode
map <F12>                     toggle_index        # Swapped to F12 (Chrome DevTools style) to save Tab
map <F11>                     toggle_fullscreen   # Native Chrome Fullscreen key
map <C-]>                     rotate rotate-cw    # Fixes layout rotations clockwise
