{
  "$schema": "https://opencode.ai/config.json",

  "compaction": {
    "auto": true,
    "prune": true,
    "threshold": 0.4,
    "reserved": 1000
  },

  "agent": {
    "build": {
      "prompt": "Act as an Adaptive Polyglot Engineer. PROTOCOL: 1. IDENTIFY: Check root for lockfiles (bun.lockb, uv.lock, package.json) to detect stack. 2. CONSTRAINTS: No conversational filler. No prose. 3. SURGICAL READS: For files >100 lines, use 'grep -n' to locate logic, then 'sed' to extract. Never 'cat' large files. 4. COMMANDS: Default to the detected manager (bun/uv/etc). If unknown, ask. 5. OUTPUT: Code blocks + 1-sentence logic justification only.",
      "permission": {
        "webfetch": "ask",
        "search": "ask",
        "bash": "allow",
        "edit": "allow"
      }
    },
    "plan": {
      "prompt": "Act as a Technical Architect. PROTOCOL: 1. MAP: Use 'ls -F' and 'grep' to find core logic paths. 2. OUTPUT: Markdown Task List only. 3. AGNOSTICISM: Structure plans based on project-specific entry points (e.g., App.tsx vs main.py). 4. NO-CODE: Do not write implementation; provide logic blueprints and file-targeting 'grep' commands for the Build agent.",
      "permission": {
        "bash": "allow",
        "edit": "deny",
        "write": "deny"
      }
    }
  },

  "watcher": {
    "ignore": [
      // Universal Dependency & Build Bloat
      "**/node_modules/**",
      "**/.venv/**",
      "**/.bun/**",
      "**/.uv/**",
      "**/dist/**",
      "**/build/**",
      "**/target/**",
      "**/out/**",
      "**/.next/**",
      "**/.expo/**",
      "**/web-build/**",
      "**/.turbo/**",
      "**/generated/**",
      // Universal Lockfiles
      "**/bun.lockb",
      "**/package-lock.json",
      "**/yarn.lock",
      "**/uv.lock",
      "**/poetry.lock",
      // Universal Junk
      "**/*.{png,jpg,jpeg,gif,svg,ico,pdf,mp4,zip,tar,gz,webp,avif,wasm}",
      "**/.git/**",
      "**/.vscode/**",
      "**/.DS_Store",
      "**/*.log",
      "**/.env*",
      "**/tsconfig.tsbuildinfo"
    ]
  },

  "permission": {
    "webfetch": "ask",
    "search": "ask",
    "bash": "ask",
    "edit": "ask"
  },

  "snapshot": true,
  "autoupdate": "notify"
}
