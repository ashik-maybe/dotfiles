{
	// =========================================================
	// 🎨 UI / WORKBENCH
	// =========================================================
	"window.autoDetectColorScheme": true,
	"workbench.preferredLightColorTheme": "Catppuccin Latte",
	"workbench.preferredDarkColorTheme": "Catppuccin Mocha",
	"workbench.iconTheme": "catppuccin-latte",

	"workbench.startupEditor": "welcomePage",
	"workbench.sideBar.location": "right",
	"workbench.activityBar.location": "top",
	"workbench.secondarySideBar.defaultVisibility": "hidden",

	"breadcrumbs.enabled": true,

	// =========================================================
	// ✍️ EDITOR — FONT / CURSOR
	// =========================================================
	"editor.fontFamily": "IntoneMonoNerdFont, monospace",
	"editor.fontSize": 16,
	"editor.lineHeight": 24,
	"editor.fontLigatures": true,

	"editor.cursorStyle": "line",
	"editor.cursorBlinking": "blink",

	// =========================================================
	// ✍️ EDITOR — BEHAVIOR
	// =========================================================
	"editor.wordWrap": "on",
	"editor.scrollBeyondLastLine": false,
	"editor.mouseWheelZoom": true,
	"editor.multiCursorModifier": "ctrlCmd",
	"editor.renderWhitespace": "selection",

	"editor.autoIndent": "full",
	"editor.autoClosingBrackets": "always",
	"editor.autoClosingQuotes": "always",
	"editor.autoSurround": "quotes",

	"editor.linkedEditing": true,

	// =========================================================
	// 🧠 EDITOR — STRUCTURE / READABILITY
	// =========================================================
	"editor.guides.indentation": true,
	"editor.guides.bracketPairs": "active",
	"editor.guides.highlightActiveBracketPair": true,

	"editor.bracketPairColorization.enabled": true,
	"editor.occurrencesHighlight": "multiFile",

	"editor.rulers": [80, 120],

	"editor.minimap.enabled": false,
	"editor.stickyScroll.enabled": false,

	// =========================================================
	// ⚡ EDITOR — SAVE / FORMAT
	// =========================================================
	"editor.formatOnSave": true,
	"editor.formatOnPaste": true,
	"editor.formatOnType": true,

	"editor.codeActionsOnSave": {
		// "source.fixAll.eslint": "always",
		// "source.organizeImports.eslint": "always"

		"source.fixAll.biome": "explicit",
		"source.organizeImports.biome": "explicit"
	},

	// =========================================================
	// 💡 INTELLISENSE
	// =========================================================
	"editor.quickSuggestions": {
		"comments": true,
		"strings": true,
		"other": true
	},

	"editor.suggestSelection": "first",
	"editor.suggest.preview": true,
	"editor.suggest.showWords": true,
	"editor.suggest.showMethods": true,
	"editor.suggest.shareSuggestSelections": true,

	"editor.acceptSuggestionOnEnter": "off",
	"editor.acceptSuggestionOnCommitCharacter": false,

	"editor.tabCompletion": "on",
	"editor.wordBasedSuggestions": "off",

	"editor.hover.delay": 500,

	// =========================================================
	// 🤖 AI / COPILOT
	// =========================================================
	"chat.mcp.gallery.enabled": true,

	"editor.inlineSuggest.enabled": true,

	"github.copilot.enable": {
		"*": true,
		"plaintext": false,
		"markdown": false,
		"scminput": false
	},
	"github.copilot.nextEditSuggestions.enabled": true,

	// =========================================================
	// 📂 FILES
	// =========================================================
	"files.insertFinalNewline": true,
	"files.trimTrailingWhitespace": true,
	"files.eol": "\n",

	"files.autoSave": "afterDelay",
	"files.autoSaveDelay": 1000,

	"files.exclude": {
		"**/.DS_Store": true,
		"**/.git": true,
		"**/build": true,
		"**/dist": true,
		"**/node_modules": true,
		"**/.next": true
	},

	// Reduce filesystem watcher overhead
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		// Node ecosystem
		"**/node_modules/*/**": true,
		// Next.js
		"**/.next/**": true,
		// Expo / React Native
		"**/.expo/**": true,
		"**/.expo-shared/**": true,
		// Build / test outputs
		"**/dist/**": true,
		"**/build/**": true,
		"**/coverage/**": true,
		// Package manager caches
		"**/.npm/**": true,
		"**/.pnpm-store/**": true,
		"**/.yarn/**": true,
		"**/.yarn/cache/**": true,
		"**/.yarn/unplugged/**": true,
		"**/.bun/**": true,
		"**/.cache/**": true,
		"**/.turbo/**": true
	},

	// =========================================================
	// 📂 EXPLORER
	// =========================================================
	"explorer.compactFolders": false,
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,

	// =========================================================
	// 🔍 SEARCH
	// =========================================================
	"search.smartCase": true,

	// =========================================================
	// 🧩 GIT
	// =========================================================
	"git.autofetch": true,

	"gitlens.codeLens.enabled": true,
	"gitlens.hovers.currentLine.over": "line",

	// =========================================================
	// 🖥 TERMINAL
	// =========================================================
	"terminal.integrated.fontFamily": "IntoneMonoNerdFont, monospace",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.scrollback": 10000,

	// =========================================================
	// 🔥 JAVASCRIPT / TYPESCRIPT
	// =========================================================
	"typescript.updateImportsOnFileMove.enabled": "always",
	"javascript.updateImportsOnFileMove.enabled": "always",

	"typescript.preferences.importModuleSpecifier": "relative",
	"javascript.preferences.importModuleSpecifier": "relative",

	"typescript.preferences.quoteStyle": "single",
	"javascript.preferences.quoteStyle": "single",

	"typescript.suggest.autoImports": true,
	"javascript.suggest.autoImports": true,

	"typescript.inlayHints.parameterNames.enabled": "literals",
	"typescript.inlayHints.enumMemberValues.enabled": true,

	"typescript.tsserver.maxTsServerMemory": 1024,
	"typescript.tsserver.log": "off",

	"totalTypeScript.hideAllTips": false,
	"totalTypeScript.hideBasicTips": false,

	// =========================================================
	// 🌐 FORMATTERS
	// =========================================================

	// ---------- PRETTIER ----------
	// "editor.defaultFormatter": "esbenp.prettier-vscode",
	// "[javascript][javascriptreact][typescript][typescriptreact][json][jsonc][html][css][markdown]": {
	// 	"editor.defaultFormatter": "esbenp.prettier-vscode"
	// },

	// ---------- SVELTE ----------
	// "[svelte]": {
	// 	"editor.defaultFormatter": "svelte.svelte-vscode"
	// },

	// ---------- BIOME ----------
	"editor.defaultFormatter": "biomejs.biome",
	"[javascript][javascriptreact][typescript][typescriptreact][json][jsonc][html][css][markdown]": {
		"editor.defaultFormatter": "biomejs.biome"
	},

	// =========================================================
	// 🐍 PYTHON
	// =========================================================
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.ruff": "explicit",
			"source.organizeImports.ruff": "explicit"
		}
	},

	"python.analysis.typeCheckingMode": "basic",
	"python.analysis.autoImportCompletions": true,

	"python.testing.pytestEnabled": true,
	"python.testing.unittestEnabled": true,

	// =========================================================
	// 🔒 PRIVACY / UPDATES
	// =========================================================
	"telemetry.telemetryLevel": "error",
	"redhat.telemetry.enabled": false,

	"update.mode": "manual",
	"extensions.autoUpdate": true,
	"extensions.ignoreRecommendations": true,

	// =========================================================
	// 🌐 SCHEMA TRUST
	// =========================================================
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://biomejs.dev": true
	},

	// =========================================================
	// 🧩 EXTENSIONS
	// =========================================================
	"tailwindCSS.classAttributes": ["class", "className", "headerClassName"]
}
